# Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# OpenCode API key (used for both Go and Zen endpoints)
OPENCODE_API_KEY=your_opencode_key_here

# Which provider and model to use for the AI fallback
# Provider options: opencodego, opencodezen
# Go models: glm-5, glm-5.1, kimi-k2.5, mimo-v2-pro, mimo-v2-omni, minimax-m2.5, minimax-m2.7
# Zen models: claude-sonnet-4-6, gpt-5.4, gpt-5.4-mini, glm-5.1, kimi-k2.5, gemini-3.1-pro, ...
AI_PROVIDER=opencodego
AI_MODEL=glm-5.1

# System prompt for the AI
SYSTEM_PROMPT=You are a helpful assistant.

# Max messages to keep in per-user conversation history (resets on restart)
MAX_HISTORY_MESSAGES=20

# Path to the SQLite database (stores scheduled jobs and user facts)
DB_PATH=madbot.db

# Set to true to enable DEBUG-level logging (useful for diagnosing scheduler/timezone/AI issues)
DEBUG=false

# Owner chat ID — Telegram user ID allowed to use /quit and /restart (and receives startup notifications)
# Leave at 0 to disable owner-only commands
OWNER_CHAT_ID=0

# Path to write log output (optional — leave blank to log to stdout only)
# When set, the bot also writes logs to this file (readable via AI introspection tools)
LOG_FILE=

# Amazon Orders (optional — leave blank to disable)
AMAZON_USERNAME=your.email@example.com
AMAZON_PASSWORD=your_amazon_password
AMAZON_OTP_SECRET=    # TOTP secret for 2FA (optional)
